<section id="education" class="education-section">
    <div class="container">
        <div class="education-layout">
            
            <div class="edu-main">
                <h2 class="section-title">
                   <span class="accent-num">04.</span> Education
                </h2>
        
                <div class="education-list">
                    <% data.education.forEach(function(edu, i) { %>
                        <div class="edu-item reveal" style="transition-delay: <%= i * 0.1 %>s">
                            <div class="edu-visual">
                                <div class="edu-dot">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                                <div class="edu-connector"></div>
                            </div>

                            <div class="edu-card">
                                <div class="edu-card-header">
                                    <span class="edu-type-tag">Degree</span>
                                    <span class="edu-timeline"><%= edu.year %></span> 
                                </div>
                                
                                <h3 class="edu-degree-title"><%= edu.degree %></h3>
                                <p class="edu-university-name"><%= edu.university %></p>
                                
                                <% let collegeName = edu.college || edu.collage; %>
                                <% if(collegeName) { %>
                                    <div class="edu-college-box">
                                        <i class="fas fa-university"></i>
                                        <span><%= collegeName %></span> 
                                    </div>
                                <% } %>

                                <% if(edu.percentage) { %>
                                    <div class="edu-score-row">
                                        <span class="label">Score:</span>
                                        <span class="value"><%= edu.percentage %></span> 
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>

            <div class="edu-sidebar-visual">
                <div class="edu-sticky-badge">
                    <i class="fa-solid fa-user-gear"></i>
                    <h3>Academic Foundation</h3>
                    <p>Continuous learning loop backing up structural development paradigms and architectural scalable patterns.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    /* Section Wrapper Base */
    .education-section {
        padding-top: var(--section-padding, 80px);
        padding-bottom: var(--section-padding, 60px);
        width: 100%;
        box-sizing: border-box;
    }

    /* Base Layout Configuration - Mobile First Default Matrix */
    .education-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        width: 100%;
    }

    .accent-num { color: var(--flutter-cyan); }
    
    /* Timeline Layout Architecture */
    .education-list { 
        display: flex; 
        flex-direction: column; 
        gap: 25px; 
    }
    
    .edu-item { 
        display: flex; 
        gap: 20px; 
        position: relative; 
    }

    /* Last node line fade out trace configuration */
    .edu-item:last-child .edu-connector {
        background: linear-gradient(to bottom, var(--flutter-cyan) 20%, transparent 100%);
        opacity: 0.1;
    }

    .edu-visual {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
    }

    .edu-dot {
        width: 42px;
        height: 42px;
        background: rgba(2, 123, 227, 0.08);
        border: 1px solid var(--flutter-cyan);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--flutter-sky, #40D1FB);
        font-size: 0.95rem;
        box-shadow: 0 0 15px rgba(2, 123, 227, 0.1);
        z-index: 2;
    }

    .edu-connector {
        width: 2px;
        flex-grow: 1;
        background: var(--flutter-cyan);
        opacity: 0.15;
        margin-top: 4px;
    }

    /* Content Cards Structural Box Mapping */
    .edu-card {
        background: var(--bg-card, rgba(255, 255, 255, 0.02));
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 24px;
        border-radius: 20px;
        flex-grow: 1;
        transition: var(--transition-smooth, all 0.35s ease);
        min-width: 0; 
        box-sizing: border-box;
    }

    .edu-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
        gap: 12px;
    }

    .edu-type-tag {
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        background: rgba(2, 123, 227, 0.15);
        border: 1px solid rgba(2, 123, 227, 0.2);
        color: var(--flutter-sky, #40D1FB);
        padding: 4px 12px;
        border-radius: 6px;
        font-weight: 700;
        white-space: nowrap;
    }

    .edu-timeline { 
        color: var(--text-dim, #a0a0a0); 
        font-family: 'Space Mono', monospace; 
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .edu-degree-title { 
        font-size: clamp(1.2rem, 2.5vw, 1.5rem); 
        color: var(--white, #fff); 
        font-weight: 800;
        margin-bottom: 6px; 
        line-height: 1.3;
        word-break: break-word;
    }

    .edu-university-name { 
        color: #aaaaaa; 
        font-weight: 500; 
        margin-bottom: 16px; 
        font-size: 0.95rem;
        word-break: break-word;
    }

    .edu-college-box {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.85rem;
        color: #8c8c8c;
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.04);
        padding: 12px 14px;
        border-radius: 12px;
        margin-bottom: 16px;
        box-sizing: border-box;
    }
    .edu-college-box i { margin-top: 3px; color: var(--flutter-cyan); opacity: 0.8; }

    .edu-score-row {
        margin-top: 15px; 
        display: inline-flex; 
        align-items: center; 
        gap: 8px;
        background: rgba(16, 185, 129, 0.06);
        border: 1px solid rgba(16, 185, 129, 0.15);
        padding: 4px 12px;
        border-radius: 8px;
    }
    .edu-score-row .label {
        font-size: 0.75rem; 
        color: #a3a3a3; 
        font-weight: 700; 
        text-transform: uppercase; 
        letter-spacing: 0.5px;
    }
    .edu-score-row .value {
        font-size: 0.85rem; 
        color: #10b981; 
        font-weight: 800;
    }

    /* Desktop Sidebar Component Configurations */
    .edu-sidebar-visual {
        display: none;
        align-items: flex-start;
        justify-content: center;
        padding-top: 70px;
    }
    .edu-sticky-badge {
        position: sticky;
        top: 120px; /* Sticks smoothly while browsing the left timeline feed */
        background: linear-gradient(135deg, rgba(2, 123, 227, 0.05) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px dashed rgba(2, 123, 227, 0.2);
        padding: 45px 30px;
        border-radius: 24px;
        text-align: center;
        max-width: 280px;
        transition: var(--transition-smooth, all 0.3s ease);
    }
    .edu-sticky-badge i {
        font-size: 2.6rem;
        color: var(--flutter-cyan);
        margin-bottom: 18px;
        text-shadow: 0 0 20px rgba(2, 123, 227, 0.2);
    }
    .edu-sticky-badge h3 {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: 10px;
        color: #fff;
    }
    .edu-sticky-badge p {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.6;
        font-family: 'Space Mono', monospace;
    }

    /* ==========================================
       RESPONSIVE BREAKPOINTS ENGINE
       ========================================== */
    @media screen and (min-width: 768px) {
        .edu-card { padding: 28px; }
    }

    /* PC Monitor Layout Configuration */
    @media screen and (min-width: 1024px) {
        .education-layout { 
            grid-template-columns: 1.6fr 0.9fr; 
            gap: 50px; 
        }
        .edu-sidebar-visual { display: flex; } 
        
        .edu-card:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(64, 209, 251, 0.4);
            transform: translateX(8px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }
        .edu-sticky-badge:hover {
            border-color: var(--flutter-sky);
            transform: translateY(-4px);
            background: rgba(2, 123, 227, 0.08);
        }
    }

    /* Smartphone Bounds Protection */
    @media screen and (max-width: 600px) {
        .education-section { padding-top: 40px; padding-bottom: 40px; }
        .edu-item { gap: 12px; }
        .edu-dot { width: 36px; height: 36px; font-size: 0.85rem; border-radius: 10px; }
        .edu-card { padding: 16px; border-radius: 16px; }
        
        .edu-card-header { 
            flex-direction: column; 
            align-items: flex-start; 
            gap: 8px; 
            margin-bottom: 12px;
        }
        .edu-timeline { font-size: 0.75rem; }
        .edu-university-name { font-size: 0.85rem; margin-bottom: 12px; }
        .edu-college-box { padding: 10px; font-size: 0.8rem; gap: 8px; }
        .edu-degree-title { font-size: 1.15rem; }
    }

    @media screen and (max-width: 380px) {
        .edu-item { gap: 8px; }
        .edu-card { padding: 12px; }
        .edu-score-row { padding: 4px 8px; }
    }

    /* Print Logic */
    @media print {
        .edu-card { background: rgba(255,255,255,0.04) !important; border: 1px solid rgba(255,255,255,0.1) !important; }
        .edu-dot { background: rgba(2, 123, 227, 0.08) !important; -webkit-print-color-adjust: exact; }
        .edu-sidebar-visual { display: none !important; }
        .education-layout { grid-template-columns: 1fr !important; }
    }
</style>