<section id="education" style="margin-top: 80px; padding-bottom: 50px;">
    <div class="education-layout">
        
        <div class="edu-main">
            <h2 class="section-title" style="font-size: clamp(2rem, 5vw, 2.5rem); display: flex; align-items: center; gap: 15px; margin-bottom: 40px;">
               <span class="accent-num">04.</span> Education
            </h2>
    
            <div class="education-list">
                <% data.education.forEach(function(edu, i) { %>
                    <div class="edu-item reveal" style="transition-delay: <%= i * 0.1 %>s">
                        <div class="edu-visual">
                            <div class="edu-dot">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <div class="edu-connector"></div>
                        </div>

                        <div class="edu-card">
                            <div class="edu-card-header">
                                <span class="edu-type-tag">Degree</span>
                                <span class="edu-timeline"><%= edu.year %></span> 
                            </div>
                            
                            <h3 class="edu-degree-title"><%= edu.degree %></h3>
                            <p class="edu-university-name"><%= edu.university %></p>
                            
                            <% let collegeName = edu.college || edu.collage; %>
                            <% if(collegeName) { %>
                                <div class="edu-college-box">
                                    <i class="fas fa-university"></i>
                                    <span><%= collegeName %></span> 
                                </div>
                            <% } %>

                            <% if(edu.percentage) { %>
                                <div class="edu-score-row" style="margin-top: 15px; display: flex; align-items: center; gap: 8px;">
                                    <span class="label" style="font-size: 0.85rem; color: #64748b; font-weight: 600; uppercase; tracking-wider;">Score:</span>
                                    <span class="value" style="font-size: 0.9rem; color: #10b981; font-weight: 700; bg-color: rgba(16,185,129,0.1); padding: 2px 8px; rounded: 4px;"><%= edu.percentage %></span> 
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</section>

<style>
    /* Desktop Grid Layout */
    .education-layout {
        display: grid;
        grid-template-columns: 1.8fr 1fr;
        gap: 50px;
    }

    .accent-num { color: var(--flutter-cyan); }
    
    /* Timeline Logic */
    .education-list { display: flex; flex-direction: column; gap: 10px; }
    .edu-item { display: flex; gap: 20px; }

    .edu-visual {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
    }

    .edu-dot {
        width: 40px;
        height: 40px;
        background: rgba(2, 123, 227, 0.1);
        border: 1px solid var(--flutter-cyan);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--flutter-cyan);
        font-size: 0.9rem;
    }

    .edu-connector {
        width: 2px;
        flex-grow: 1;
        background: linear-gradient(to bottom, var(--flutter-cyan), transparent);
        margin: 8px 0;
        opacity: 0.2;
    }

    /* Card UI */
    .edu-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.07);
        padding: 20px;
        border-radius: 16px;
        flex-grow: 1;
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        min-width: 0; /* Prevents overflow */
    }

    .edu-card:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: var(--flutter-cyan);
        transform: translateX(5px);
    }

    .edu-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        gap: 10px;
    }

    .edu-type-tag {
        font-size: 0.65rem;
        text-transform: uppercase;
        background: rgba(2, 123, 227, 0.2);
        color: var(--flutter-cyan);
        padding: 3px 10px;
        border-radius: 4px;
        font-weight: bold;
        white-space: nowrap;
    }

    .edu-timeline { 
        color: #666; 
        font-family: 'Space Mono', monospace; 
        font-size: 0.8rem; 
        white-space: nowrap;
    }

    .edu-degree-title { 
        font-size: clamp(1.1rem, 3vw, 1.4rem); 
        color: #fff; 
        margin-bottom: 6px; 
        line-height: 1.3;
    }

    .edu-university-name { 
        color: #bbb; 
        font-weight: 500; 
        margin-bottom: 15px; 
        font-size: 0.95rem;
    }

    .edu-college-box {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.85rem;
        color: #888;
        background: rgba(0,0,0,0.15);
        padding: 10px 12px;
        border-radius: 10px;
        margin-bottom: 15px;
    }
    .edu-college-box i { margin-top: 3px; color: var(--flutter-cyan); opacity: 0.7; }

    .edu-spec-row { font-size: 0.85rem; display: flex; flex-wrap: wrap; }
    .edu-spec-row .label { color: #555; margin-right: 8px; }
    .edu-spec-row .value { color: var(--flutter-cyan); font-weight: 500; }

    /* Responsive Queries */
    @media (max-width: 992px) {
        .education-layout { grid-template-columns: 1fr; gap: 30px; }
    }

    @media (max-width: 600px) {
        #education { margin-top: 60px !important; }
        .edu-item { gap: 15px; }
        .edu-dot { width: 34px; height: 34px; font-size: 0.8rem; }
        .edu-card { padding: 16px; }
        .edu-card-header { flex-direction: row; justify-content: space-between; }
        .edu-timeline { font-size: 0.75rem; }
        .edu-university-name { font-size: 0.85rem; }
    }

    /* Print Logic (Maintain Dark Background as per previous requirement) */
    @media print {
        #education { margin-top: 30px !important; }
        .edu-card { background: rgba(255,255,255,0.05) !important; border: 1px solid rgba(255,255,255,0.1) !important; }
        .edu-dot { background: rgba(2, 123, 227, 0.1) !important; -webkit-print-color-adjust: exact; }
    }
</style>