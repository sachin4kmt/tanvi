<section id="experience" class="experience-section" data-aos="fade-up" data-aos-duration="800">
    <div class="container">
        <h2 class="section-title">
            <span class="accent-num">03.</span> Experience
        </h2>

        <div class="experience-list">
            <% data.experience.forEach(function(exp, index) { %>
                <div class="project-card reveal" data-aos="fade-up" data-aos-duration="700" data-aos-delay="<%= index * 80 %>">

                    <div class="exp-header">
                        <div class="exp-title-box">
                            <a href="<%= exp.website %>" target="_blank" class="company-link">
                                <%= exp.company %> <i class="fas fa-external-link-alt"></i>
                            </a>
                            <p class="exp-role"><%= exp.role %></p>
                        </div>

                        <div class="exp-duration">
                            <span><%= exp.duration %></span>
                        </div>
                    </div>

                    <div class="exp-details-box">
                        <p class="exp-text"><%= exp.details %></p>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>
