<footer class="portfolio-footer">
    <div class="container">
        <p class="widget-label mono">&gt; RETURN_CONTACT</p>
        
        <h2 class="footer-email-heading">
            <a href="mailto:<%= data.email %>" class="footer-mail-link">
                <%= data.email %>
            </a>
        </h2>
        
        <div class="footer-meta-row mono">
            <span><i class="fas fa-map-marker-alt"></i> <%= data.location %></span>
            <span><i class="fab fa-github"></i> <a href="https://<%= data.github %>" target="_blank"><%= data.github.split('/').pop() %></a></span>
        </div>
        
        <p class="footer-copyright">
            © 2026 <span class="accent-text"><%= data.name %></span>. All Rights Reserved. Built with Node.js & EJS.
        </p>
    </div>
</footer>

<style>
    .portfolio-footer {
        padding: 80px 0; 
        text-align: center; 
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        background: linear-gradient(to top, rgba(2, 123, 227, 0.02) 0%, transparent 100%);
        width: 100%;
        box-sizing: border-box;
    }

    .footer-email-heading {
        font-size: clamp(1.3rem, 4.5vw, 2.6rem); 
        margin-top: 15px;
        margin-bottom: 25px;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .footer-mail-link {
        color: #fff;
        text-decoration: none;
        transition: var(--transition-smooth, all 0.3s ease);
        word-break: break-all; /* Strict safeguard for ultra-narrow phones */
    }

    .footer-mail-link:hover {
        color: var(--flutter-cyan);
        text-shadow: 0 0 30px rgba(2, 123, 227, 0.3);
    }

    .footer-meta-row {
        display: flex;
        justify-content: center;
        gap: 25px;
        color: var(--text-dim, #a0a0a0);
        font-size: 0.85rem;
        margin-bottom: 35px;
        flex-wrap: wrap;
    }

    .footer-meta-row a {
        color: var(--text-dim, #a0a0a0);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .footer-meta-row a:hover {
        color: var(--flutter-sky, #40D1FB);
    }

    .footer-meta-row i {
        color: var(--flutter-cyan);
    }

    .footer-copyright {
        opacity: 0.4; 
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        line-height: 1.5;
    }

    .accent-text {
        color: #fff;
        font-weight: 600;
        opacity: 0.9;
    }

    /* ==========================================
       BREAKPOINTS (MOBILE ADJUSTMENTS)
       ========================================== */
    @media (max-width: 600px) {
        .portfolio-footer {
            padding: 60px 0 40px;
        }
        .footer-meta-row {
            flex-direction: column;
            gap: 12px;
            align-items: center;
        }
        .footer-copyright {
            font-size: 0.75rem;
            padding: 0 10px;
        }
    }

    /* PRINT CLEANUP */
    @media print {
        .portfolio-footer { padding: 40px 0 !important; }
        .footer-mail-link { color: #000 !important; text-decoration: underline !important; }
    }
</style>