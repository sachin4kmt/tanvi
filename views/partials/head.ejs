<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Technical Identity -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <!-- Dynamic Title: Pulling from Senior Flutter Developer role -->
    <title><%= data.name %> | <%= data.role %></title>
    
    <!-- SEO Meta Tags -->
    <meta name="title" content="<%= data.name %> - Portfolio">
    <meta name="description" content="<%= data.summary %>">
    <meta name="keywords" content="Flutter, Dart, GetX, Clean Architecture, Mobile App Development, <%= data.location %>, Senior Engineer, Mac mini M4, B2B Apps, Fintech">
    <meta name="author" content="<%= data.name %>">

    <!-- Open Graph / LinkedIn / Social Sharing -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://<%= data.github %>">
    <meta property="og:title" content="<%= data.name %> | <%= data.role %>">
    <meta property="og:description" content="Check out my production-grade Flutter apps built with Clean Architecture and SOLID principles.">
    <meta property="og:image" content="/images/og-preview.png"> <!-- Make sure this image exists for LinkedIn previews -->

    <!-- Twitter Optimization -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://<%= data.github %>">
    <meta property="twitter:title" content="<%= data.name %> | Flutter Expert">
    <meta property="twitter:description" content="<%= data.summary %>">

    <!-- External Assets -->
    <!-- GSAP: Critical for your "reveal" animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <!-- Professional Typefaces -->
    <!-- JetBrains Mono for Code, Space Mono for Stats/Dates, Plus Jakarta for UI -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <!-- FontAwesome 6.4.2 (Latest Stable for Android/iOS icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Favicon & Brand Color -->
    <link rel="icon" type="image/png" href="/images/logo.png">
    <meta name="theme-color" content="#027BE3"> <!-- Flutter Cyan for Mobile UI -->

    <!-- Core Design Tokens (CSS Variables) -->
    <style>
        :root {
            /* Primary Colors */
            --flutter-cyan: #027BE3;
            --flutter-sky: #40D1FB;
            --bg-dark: #050505; /* Deeper black for high contrast */
            --bg-card: rgba(255, 255, 255, 0.03);
            
            /* Text Colors */
            --white: #FFFFFF;
            --text-dim: #A0A0A0;
            --text-muted: #555555;

            /* Effects */
            --border-glow: rgba(2, 123, 227, 0.2);
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            
            /* Logic for Scroll Reveal */
            --reveal-opacity: 0;
            --reveal-y: 30px;
        }

        /* Essential Reset for Dark Theme */
        body {
            background-color: var(--bg-dark);
            color: var(--white);
            font-family: 'Plus+Jakarta+Sans', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* Mono text for tech tags and terminal-style dates */
        .mono { font-family: 'Space Mono', monospace; }
        .code { font-family: 'JetBrains Mono', monospace; }
    </style>
</head>