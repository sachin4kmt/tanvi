<section class="hero">
    <div class="container">
        <div class="hero-wrapper">

            <div class="hero-content">
                <div class="widget-label reveal">
                    &gt; <%= data.role %>
                </div>

                <h1 class="reveal">
                    I'm <span class="gradient-text"><%= data.name %></span>
                </h1>

                <p class="hero-summary reveal">
                    <%= data.summary %>
                </p>

                <div class="hero-meta reveal">
                    <div class="meta-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <span><%= data.location %></span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-terminal"></i>
                        <span><%= data.experience_years %> Experience</span>
                    </div>
                </div>

                <div class="hero-btns reveal">
                    <a href="mailto:<%= data.email %>" class="btn-primary">
                        Email <i class="fas fa-envelope"></i>
                    </a>
                    <a href="https://<%= data.linkedin %>" target="_blank" class="btn-linkedin">
                        <i class="fab fa-linkedin"></i> LinkedIn
                    </a>
                    <a href="/download-resume" class="btn-secondary-pdf">
                        <i class="fas fa-cloud-arrow-down"></i> Resume PDF
                    </a>
                    <button type="button" onclick="sharePortfolio()" class="btn-share-profile">
                        <i class="fas fa-share-alt"></i> Share
                    </button>
                </div>
            </div>

            <div class="hero-visual reveal">
                <div class="tech-card">
                    <div class="card-header">
                        <div class="dots"><span></span><span></span><span></span></div>
                        <span class="file-name"><%= data.name.toLowerCase() %>_profile.dart</span>
                    </div>
                    <div class="card-body">
                        <pre><code><span class="keyword">class</span> <span class="class-name">MobileAppDeveloper</span> {
  String name = <span class="string">'<%= data.name %>'</span>;
  List&lt;String&gt; stack = [
    <span class="string">'Flutter'</span>, <span class="string">'Dart'</span>, <span class="string">'Firebase'</span>
  ];
  <span class="keyword">bool</span> isReadyToImpact = <span class="keyword">true</span>;
}</code></pre>
                    </div>
                </div>
                <div class="hero-glow"></div>
            </div>
        </div>
    </div>
</section>
