<section id="projects" class="projects-section">
    <div class="container">
        <h2 class="section-title">
            <span class="accent-num">01.</span> Projects
        </h2>

        <% data.projects.forEach(function(p, i) {
            const company = data.experience.find(e => e.id === p.companyId);
            const hasScreenshots = p.screenshots && p.screenshots.length > 0;
            const descriptionText = p.description || "";
            const shortDescription = descriptionText.length > 320 ? descriptionText.substring(0, 320) + "..." : descriptionText;
            const needsReadMore = descriptionText.length > 320;
            const delayPhone = i * 40;
            const delayInfo = (i * 60) + 60;
        %>

        <div class="project-container-context">
            <div class="project-card reveal">

                <div class="phone-mockup" data-aos="fade-right" data-aos-offset="160" data-aos-duration="800" data-aos-delay="<%= delayPhone %>">
                    <div class="mockup-content">
                        <% if(hasScreenshots) { %>
                            <% if(p.screenshots.length > 1) { %>
                                <button type="button" class="phone-nav-btn left-btn" onclick="slidePhone('<%= i %>', -1)" aria-label="Previous screenshot">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button type="button" class="phone-nav-btn right-btn" onclick="slidePhone('<%= i %>', 1)" aria-label="Next screenshot">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            <% } %>

                            <div class="phone-slider-horizontal" id="phone-slider-<%= i %>">
                                <% p.screenshots.forEach(function(ss) { %>
                                    <img src="<%= ss %>" class="phone-screen-img" alt="<%= p.title %> preview">
                                <% }); %>
                            </div>
                        <% } else if(p.logo) { %>
                            <div class="logo-fallback">
                                <img src="<%= p.logo %>" alt="<%= p.title %> logo">
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="project-info" data-aos="fade-left" data-aos-offset="160" data-aos-duration="800" data-aos-delay="<%= delayInfo %>">
                    <% if(company) { %>
                        <p class="widget-label project-company-label">
                            <a href="<%= company.website %>" target="_blank" class="company-link-inline">
                                <i class="fas fa-link"></i> <%= company.company %>
                            </a>
                            <span class="project-tag">/ <%= p.tag %></span>
                        </p>
                    <% } %>

                    <div class="title-row">
                        <% if(p.logo) { %>
                            <div class="logo-wrapper">
                                <img src="<%= p.logo %>" alt="<%= p.title %> logo">
                            </div>
                        <% } %>
                        <h3 class="project-title"><%= p.title %></h3>
                    </div>

                    <div class="description-wrapper">
                        <p id="desc-short-<%= i %>" class="description short-desc"><%= shortDescription %></p>
                        <div id="desc-full-<%= i %>" class="description full-desc" style="display: none;"><p><%= p.description %></p></div>
                        <% if(needsReadMore) { %>
                            <button type="button" class="read-more-btn" onclick="toggleDescription(<%= i %>)" id="btn-<%= i %>">
                                <span id="btn-text-<%= i %>">Read More</span>
                                <i id="btn-icon-<%= i %>" class="fas fa-chevron-down"></i>
                            </button>
                        <% } %>
                    </div>

                    <div class="tech-stack-container">
                        <% if(p.tech) { p.tech.forEach(function(t) { %>
                            <span class="tech-badge"><%= t %></span>
                        <% }); } %>
                    </div>

                    <% if(hasScreenshots) { %>
                        <div class="screenshot-gallery">
                            <% p.screenshots.forEach(function(ss, ssIndex) { %>
                                <img src="<%= ss %>" class="ss-img" alt="<%= p.title %> screenshot" onclick="jumpToSlide('<%= i %>', <%= ssIndex %>)">
                            <% }); %>
                        </div>
                    <% } %>

                    <div class="app-links">
                        <% if(p.android_link && p.android_link !== "#") { %>
                            <a href="<%= p.android_link %>" target="_blank" class="app-btn">
                                <i class="fab fa-android"></i> Play Store
                            </a>
                        <% } %>
                        <% if(p.ios_link && p.ios_link !== "#") { %>
                            <a href="<%= p.ios_link %>" target="_blank" class="app-btn">
                                <i class="fab fa-apple"></i> App Store
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</section>
