<style>
    :root {
        /* Premium Flutter Palette */
        --flutter-blue: #02569B;
        --flutter-cyan: #01C8FF;
        --bg: #050a0f;
        --card-bg: rgba(255, 255, 255, 0.02);
        --glass-border: rgba(255, 255, 255, 0.08);
        --text-main: #ffffff;
        --text-dim: #a0a0a0;
        --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    
    body { 
        background-color: var(--bg); 
        color: var(--text-main); 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        overflow-x: hidden;
        line-height: 1.6;
    }

    /* Ambient Glow (Optimized for Mobile) */
    body::before {
        content: ''; position: fixed; top: -10%; left: -10%; width: 50%; height: 50%;
        background: radial-gradient(circle, rgba(1, 200, 255, 0.07) 0%, transparent 70%); 
        z-index: -1; pointer-events: none;
    }

    /* Responsive Container */
    .container { 
        width: 100%;
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 0 40px; 
    }

    /* Project Cards Logic */
    .project-card { 
        background: var(--card-bg); 
        border: 1px solid var(--glass-border); 
        border-radius: 32px; 
        padding: 45px; 
        display: grid;
        grid-template-columns: 1.2fr 0.8fr; /* Desktop: Content | Mockup */
        gap: 50px; 
        margin-bottom: 60px; 
        backdrop-filter: blur(15px); 
        transition: var(--transition); 
        overflow: hidden;
    }

    .project-card:hover { 
        border-color: rgba(1, 200, 255, 0.4); 
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.04);
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    }

    /* Gallery (Standardize scroll) */
    .screenshot-gallery { 
        display: flex; 
        gap: 12px; 
        overflow-x: auto; 
        margin: 25px 0; 
        padding-bottom: 10px; 
        width: 100%;
        scrollbar-width: thin;
        scrollbar-color: var(--flutter-cyan) transparent;
        -webkit-overflow-scrolling: touch; /* Smooth iOS scroll */
    }

    /* Phone Mockup (Adaptive Scaling) */
    .phone-mockup { 
        width: 100%;
        max-width: 260px; 
        aspect-ratio: 9/19;
        height: auto;
        background: #000; 
        border: 10px solid #1a1a1a; 
        border-radius: 40px; 
        justify-self: center;
        position: relative; 
        overflow: hidden; 
        box-shadow: 0 30px 60px rgba(0,0,0,0.6); 
    }

    /* Links & Buttons (Touch Friendly) */
    .app-links { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    
    .app-btn { 
        flex: 1; /* Stretch on mobile */
        min-width: 140px;
        justify-content: center;
        text-decoration: none; 
        color: #fff; 
        background: rgba(255, 255, 255, 0.03); 
        border: 1px solid var(--glass-border); 
        padding: 14px 20px; 
        border-radius: 16px; 
        font-size: 0.85rem; 
        font-weight: 600;
        display: inline-flex; 
        align-items: center; 
        gap: 10px; 
        transition: var(--transition); 
    }

    /* MOBILE BREAKPOINTS (The Real Update) */
    @media (max-width: 992px) {
        .container { padding: 0 25px; }
        .project-card { 
            grid-template-columns: 1fr; /* Stack visually */
            padding: 30px;
            gap: 40px;
        }
        .hero-wrapper {
            grid-template-columns: 1fr;
            text-align: center;
        }
    }

    @media (max-width: 600px) {
        h1 { font-size: 2.2rem !important; }
        .section-title { font-size: 1.8rem !important; }
        
        .project-card { 
            border-radius: 24px;
            padding: 20px;
        }

        .phone-mockup {
            max-width: 220px; /* Smaller phone on mobile */
        }

        .app-btn {
            width: 100%; /* Full width buttons on tiny screens */
            flex: none;
        }

        .hero-meta {
            flex-direction: column;
            gap: 15px;
            align-items: center;
        }
    }

    /* Reveal Animation Active */
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }

    /* Print Fix (Ensures background isn't black when exporting PDF) */
    @media print {
        body { background: #fff !important; color: #000 !important; }
        .project-card { border: 1px solid #ddd !important; background: #fff !important; }
    }
</style>